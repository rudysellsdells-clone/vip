# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Product / white-label configuration
NEXT_PUBLIC_PRODUCT_APP_NAME="Rudy's VIP"
NEXT_PUBLIC_PRODUCT_BRAND_NAME="Web Search Pros OS"
NEXT_PUBLIC_PRODUCT_COMPANY_NAME="Web Search Pros"
NEXT_PUBLIC_PRODUCT_OWNER_NAME="Rudy"
NEXT_PUBLIC_PRODUCT_SUPPORT_EMAIL="support@example.com"
NEXT_PUBLIC_PRODUCT_PRIMARY_SERVICE_CATEGORY="marketing"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# AI / workflow integrations
OPENAI_API_KEY=
GALAXYAI_API_KEY=
GALAXYAI_WEBHOOK_SECRET=

# Zapier MCP
ZAPIER_MCP_SERVER_URL=
# Optional when your MCP URL is not already tokenized.
ZAPIER_MCP_TOKEN=

# Optional Zapier MCP static tool names.
# Use these if Zapier's MCP tool name is different from VIP's default.
ZAPIER_GMAIL_DRAFT_TOOL_NAME=gmail_create_draft
ZAPIER_FACEBOOK_PAGE_POST_TOOL_NAME=facebook_pages_page_stream
ZAPIER_LINKEDIN_MCP_TOOL_NAME=linkedin_create_company_update

# LinkedIn publishing target for Zapier MCP
ZAPIER_LINKEDIN_PAGE_NAME="McCormick Web Marketing"
# Optional: use this if Zapier/LinkedIn requires an organization/page ID instead of the page name.
ZAPIER_LINKEDIN_ORGANIZATION_ID=
